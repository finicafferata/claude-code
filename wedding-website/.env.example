# ─────────────────────────────────────────────────────────────
# Credenciales de Google Sheets (Service Account)
# Copiá este archivo como .env.local y completá los valores.
# NUNCA subas .env.local al repositorio.
# ─────────────────────────────────────────────────────────────

# Email de la Service Account (termina en .iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Clave privada de la Service Account.
# Copiá el valor "private_key" del JSON tal cual, entre comillas.
# Los saltos de línea van escritos como \n (el backend los convierte solo).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# ID del Google Sheet (está en la URL entre /d/ y /edit)
# Ej: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEET_ID=

# Nombre de la pestaña donde se guardan las respuestas
GOOGLE_SHEET_TAB=RSVP
